# ====================================================
# InfyHMS - Docker Environment Variables
# Copy this file to .docker.env and customize
# ====================================================

# ── Application ──────────────────────────────────
APP_NAME="InfyHMS"
APP_ENV=production
APP_KEY=base64:ZFgZenJFi7r5MwXu4ZSzbJMvjKtNB2mYjslib/uixWc=
APP_DEBUG=false
APP_URL=http://localhost:8080
APP_PORT=8080

FILESYSTEM_DISK=public
MEDIA_DISK=public

# ── Database ─────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=hms
DB_USERNAME=hms_user
DB_PASSWORD=hms_secret_change_me
DB_ROOT_PASSWORD=root_secret_change_me_123
DB_EXTERNAL_PORT=3306

# ── Redis ────────────────────────────────────────
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_EXTERNAL_PORT=6379

# ── Cache / Session / Queue ───────────────────────
CACHE_DRIVER=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
QUEUE_CONNECTION=redis

# ── Logging ──────────────────────────────────────
LOG_CHANNEL=stack
LOG_LEVEL=error

# ── Mail ─────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@yourhospital.com
MAIL_FROM_NAME="${APP_NAME}"

# ── phpMyAdmin ────────────────────────────────────
PMA_PORT=8081

# ── InfyHMS Specific ─────────────────────────────
VERSION_NUMBER=true
UPGRADE_MODE=false
COOKIE_CONSENT_ENABLED=true
DEBUGBAR_ENABLED=false
QUERY_DETECTOR_ENABLED=false
LOGVIEWER_PATTERN="*.log"

# ── Optional Integrations ─────────────────────────
# Twilio SMS
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_FROM_NUMBER=

# Stripe Payments
STRIPE_KEY=
STRIPE_SECRET_KEY=

# Zoom Integration
ZOOM_API_URL=
ZOOM_API_KEY=
ZOOM_API_SECRET=

# Google reCAPTCHA
NOCAPTCHA_SECRET=
NOCAPTCHA_SITEKEY=
